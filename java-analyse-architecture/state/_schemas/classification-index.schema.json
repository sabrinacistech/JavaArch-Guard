{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "classification-index.schema.json",
  "type": "object",
  "required": ["schemaVersion", "classes"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fqcn", "type", "score"],
        "properties": {
          "fqcn": { "type": "string" },
          "type": { "enum": ["service", "controller", "repository", "mapper", "util", "config", "dto", "generated", "entity", "exception"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "loc": { "type": "integer" },
          "publicMethods": { "type": "integer" },
          "cyclomatic": { "type": "integer" },
          "coverage": {
            "type": "object",
            "properties": {
              "lines": { "type": "number" },
              "branches": { "type": "number" }
            }
          },
          "risk": { "type": "number" },
          "score": { "type": "number" }
        }
      }
    }
  }
}
