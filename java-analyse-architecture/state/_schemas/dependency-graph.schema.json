{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dependency-graph.schema.json",
  "type": "object",
  "required": ["schemaVersion", "graphs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "graphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sut", "dependencies"],
        "properties": {
          "sut": { "type": "string" },
          "instantiationHint": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "injection"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "injection": { "enum": ["constructor", "field", "setter"] },
                "final": { "type": "boolean" }
              }
            }
          },
          "collaboratorUsage": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "type", "methods"],
              "properties": {
                "field": { "type": "string" },
                "type": { "type": "string" },
                "methods": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["evidenceId", "name", "params", "returnType"],
                    "properties": {
                      "evidenceId": { "type": "string" },
                      "name": { "type": "string" },
                      "params": { "type": "array", "items": { "type": "string" } },
                      "returnType": { "type": "string" },
                      "throws": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            }
          },
          "externalClients": { "type": "array" },
          "springStrategy": {
            "type": "object",
            "properties": {
              "slice": { "enum": ["WebMvcTest", "DataJpaTest", "none"] },
              "mockBeans": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
