{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "generated-tests.schema.json",
  "description": "Tests propuestos en el ciclo actual — escrito por generation-agent, leído por reporting-agent y cycle_summarizer.",
  "type": "object",
  "required": ["schemaVersion", "tests"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "cycle":         { "type": "integer" },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testClass", "sut", "status"],
        "properties": {
          "testClass":   { "type": "string" },
          "sut":         { "type": "string" },
          "evidenceIds": { "type": "array", "items": { "type": "string" } },
          "status":      { "enum": ["PROPOSED", "VALIDATED", "DISCARDED", "COMMITTED"] },
          "reason":      { "type": "string" },
          "patchId":     { "type": "string" }
        }
      }
    }
  }
}
